    </record>

    <record id="product_sku001" model="product.product">
        <field name="name">Green Chicken Curry</field>
        <field name="default_code">SKU001</field>
        <field name="detailed_type">product</field>
        <field name="sch_shelf_life_days">3</field>
        <field name="sch_max_capacity_qty">12</field>
        <field name="sch_min_display_qty">2</field>
    </record>

    <record id="product_sku002" model="product.product">
        <field name="name">Bio Lasagne</field>
        <field name="default_code">SKU002</field>
