<odoo>
    <record id="partner_demo_client" model="res.partner">
        <field name="name">Demo Client GmbH</field>
        <field name="is_company">True</field>
    </record>

    <record id="fridge_fr001" model="sch.fridge">
        <field name="name">Demo Office Fridge 1</field>
        <field name="code">FR001</field>
        <field name="partner_id" ref="partner_demo_client"/>
    </record>

    <record id="fridge_fr002" model="sch.fridge">
        <field name="name">Demo Office Fridge 2</field>
        <field name="code">FR002</field>
