        <field name="sch_shelf_life_days">4</field>
        <field name="sch_max_capacity_qty">10</field>
        <field name="sch_min_display_qty">2</field>
    </record>

    <record id="product_sku003" model="product.product">
        <field name="name">Porridge</field>
        <field name="default_code">SKU003</field>
