<odoo>
    <record id="view_sch_integration_run_tree" model="ir.ui.view">
        <field name="name">sch.integration.run.tree</field>
        <field name="model">sch.integration.run</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" delete="false">
                <field name="started_at"/>
                <field name="finished_at"/>
                <field name="source"/>
                <field name="state"/>
                <field name="sales_count"/>
                <field name="snapshot_count"/>
                <field name="line_count"/>
                <field name="plan_id"/>
            </tree>
        </field>
    </record>

    <record id="view_sch_integration_run_form" model="ir.ui.view">
        <field name="name">sch.integration.run.form</field>
        <field name="model">sch.integration.run</field>
        <field name="arch" type="xml">
            <form create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="source" readonly="1"/>
                        <field name="state" readonly="1"/>
                        <field name="started_at" readonly="1"/>
                        <field name="finished_at" readonly="1"/>
                    </group>
                    <group>
                        <field name="sales_count" readonly="1"/>
                        <field name="snapshot_count" readonly="1"/>
                        <field name="line_count" readonly="1"/>
                        <field name="plan_id" readonly="1"/>
                    </group>
                    <field name="message" readonly="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sch_integration_run" model="ir.actions.act_window">
        <field name="name">Sync Runs</field>
        <field name="res_model">sch.integration.run</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_sch_run_mock_sync" model="ir.actions.server">
        <field name="name">Run Mock Sync Now</field>
        <field name="model_id" ref="model_sch_integration_run"/>
        <field name="state">code</field>
        <field name="code">action = model.action_run_mock_sync()</field>
    </record>
</odoo>
